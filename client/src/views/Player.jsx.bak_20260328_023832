// Sub-component for individual voice stream playback
// Accepts shared audioContext + voiceGainNode for voice boost
function VoicePlayer({ slotId, addLog, voiceAudioContext, voiceGainNode }) {
    const audioRef = useRef(new Audio());
    const mediaSourceRef = useRef(null);
    const sourceBufferRef = useRef(null);
    const queue = useRef([]);
    const isProcessing = useRef(false);
    const activeType = useRef(null);
    const isMounted = useRef(true);
    const hasInit = useRef(false);
    const voiceSourceRef = useRef(null);

    useEffect(() => {
        isMounted.current = true;
        hasInit.current = false;
        const audio = audioRef.current;
        audio.volume = 1.0;

        // Connect voice audio to boost gain node if available
        if (voiceAudioContext && voiceGainNode && !voiceSourceRef.current) {
            try {
                voiceSourceRef.current = voiceAudioContext.createMediaElementSource(audio);
                voiceSourceRef.current.connect(voiceGainNode);
                addLog(`[Slot ${slotId}] Voice connected to boost gain (${voiceGainNode.gain.value}x)`);
            } catch (e) {
                addLog(`[Slot ${slotId}] Voice gain connect err: ${e.message}`);
            }
        }

        const handler = (e) => {
            if (!isMounted.current) return;
            const { buffer, type, header, isHeader } = e.detail;
            addLog(`[Slot ${slotId}] Rx Chunk sz=${buffer.byteLength} type=${type} isH=${isHeader}`);

            let finalType = type;
            if (type === 'audio/mp4') finalType = 'audio/mp4; codecs="mp4a.40.2"';

            if (!hasInit.current) {
                if (isHeader) {
                    queue.current.push({ buffer, type: finalType });
                    hasInit.current = true;
                } else if (header) {
                    queue.current.push({ buffer: header, type: finalType });
                    queue.current.push({ buffer, type: finalType });
                    hasInit.current = true;
                } else {
                    addLog(`[Slot ${slotId}] WARN: Discarding packet missing header`);
                    return;
                }
            } else {
                queue.current.push({ buffer, type: finalType });
            }
            processQueue();
        };

        const processQueue = async () => {
            if (isProcessing.current || !isMounted.current) return;
            if (queue.current.length === 0) return;

            const { buffer, type } = queue.current[0];
            let ms = mediaSourceRef.current;

            if (!ms || ms.readyState === 'closed') {
                isProcessing.current = true;
                ms = new MediaSource();
                mediaSourceRef.current = ms;
                audio.src = URL.createObjectURL(ms);
                addLog(`[Slot ${slotId}] Init MediaSource`);
                try {
                    await new Promise((resolve, reject) => {
                        const onOpen = () => resolve();
                        const onClose = () => reject('closed');
                        ms.addEventListener('sourceopen', onOpen, { once: true });
                        ms.addEventListener('sourceclose', onClose, { once: true });
                        setTimeout(() => {
                            ms.removeEventListener('sourceopen', onOpen);
                            ms.removeEventListener('sourceclose', onClose);
                            reject('timeout');
                        }, 500);
                    });
                } catch (e) {
                    addLog(`[Slot ${slotId}] MS Init Error: ${e}`);
                    isProcessing.current = false;
                    return;
                }
            }

            if (!isMounted.current) { isProcessing.current = false; return; }

            if (!sourceBufferRef.current || activeType.current !== type) {
                isProcessing.current = true;
                if (sourceBufferRef.current) {
                    try { if (ms.readyState === 'open') ms.removeSourceBuffer(sourceBufferRef.current); } catch { }
                }
                try {
                    if (ms.readyState !== 'open') throw new Error('MS not open');
                    const sb = ms.addSourceBuffer(type);
                    sb.mode = 'sequence';
                    sb.addEventListener('updateend', () => {
                        isProcessing.current = false;
                        processQueue();
                    });
                    sb.addEventListener('error', (e) => addLog(`[Slot ${slotId}] SB Error: ${e}`));
                    sourceBufferRef.current = sb;
                    activeType.current = type;
                    addLog(`[Slot ${slotId}] Added SB: ${type}`);
                } catch (e) {
                    addLog(`[Slot ${slotId}] Add SB Failed: ${e.message}`);
                    queue.current.shift();
                    isProcessing.current = false;
                    return;
                }
            }

            if (!isMounted.current) { isProcessing.current = false; return; }

            const sb = sourceBufferRef.current;
            if (!sb) { isProcessing.current = false; return; }
            if (sb.updating) { isProcessing.current = true; return; }

            try {
                const item = queue.current.shift();
                isProcessing.current = true;
                let data = item.buffer;
                if (data instanceof Blob) data = await data.arrayBuffer();

                if (ms.readyState === 'open' && isMounted.current) {
                    sb.appendBuffer(data);
                    if (audio.paused) {
                        audio.play().catch(() => { });
                    }
                    // Latency chase: if buffer end is too far ahead, seek forward
                    if (audio.buffered.length > 0) {
                        const buffEnd = audio.buffered.end(audio.buffered.length - 1);
                        const lag = buffEnd - audio.currentTime;
                        if (lag > 1.5) {
                            audio.currentTime = buffEnd - 0.3;
                        }
                    }
                }
            } catch (e) {
                addLog(`[Slot ${slotId}] Append Error: ${e.message}`);
                isProcessing.current = false;
            }
        };

        window.addEventListener(`voice_data_${slotId}`, handler);
        return () => {
            isMounted.current = false;
            window.removeEventListener(`voice_data_${slotId}`, handler);
            if (mediaSourceRef.current && mediaSourceRef.current.readyState === 'open') {
                try { mediaSourceRef.current.endOfStream(); } catch { }
            }
            audio.pause();
            audio.src = '';
        };
    }, [slotId]);

    return null;
}

// Admin Modal
function AdminModal({ title, onClose, onConfirm }) {
